{
  "name": "blackjack-game",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/init-swarm.sh",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:prod": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "init-swarm": "sh scripts/init-swarm.sh",
    "postinstall": "bash scripts/init-swarm.sh"
  },
  "dependencies": {
    "@h4shed/mcp-cli": "^1.0.11",
    "@h4shed/mcp-core": "^1.0.11",
    "@h4shed/skill-style-dictionary-system": "^1.0.1",
    "@h4shed/skill-syncpulse": "^0.2.0",
    "@h4shed/tool-commander": "^11.0.1",
    "framer-motion": "^10.16.16",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
